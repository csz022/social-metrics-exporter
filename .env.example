THREADS_INPUT=input/urls.txt
THREADS_SHEET=
THREADS_SHEET_PLATFORMS=ALL
THREADS_SHEET_URL_COLUMN=B
THREADS_SHEET_SCAN_FALLBACK=true
THREADS_SHEET_CACHE_SECONDS=600
THREADS_OUTPUT=output/social_metrics.csv
THREADS_FORMAT=report

# Batch behavior
THREADS_CONCURRENCY=4
THREADS_DELAY=0
THREADS_NETWORK_IDLE_TIMEOUT_MS=3000
THREADS_RETRIES=1
THREADS_HEADFUL=false
THREADS_DEBUG=false
THREADS_RESUME=false
THREADS_FAILED_OUTPUT=output/all_platform_failed_urls.csv
# Enriches IG/Facebook followers. Threads follower count stays N/A in report output.
THREADS_FETCH_FOLLOWERS=true
THREADS_PROFILE_SEARCH=false
THREADS_PROFILE_SEARCH_SCROLLS=12
THREADS_NETWORK_CAPTURE=true
THREADS_PROFILE_CACHE=.cache/profile_counts.json

# Login mode.
# GUI ignores these unless THREADS_USE_LOGIN=true or Advanced > Use saved login/session is checked.
# Run: uv run python src/main.py --login
THREADS_USE_LOGIN=false
THREADS_AUTH_STATE=.auth/threads_state.json
THREADS_PROFILE_DIR=.auth/threads_profile
THREADS_USERNAME=
THREADS_PASSWORD=
